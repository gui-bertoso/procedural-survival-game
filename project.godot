; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MyGameProject"
config/description="Um projeto de jogo meu onde basicamente tudo sera procedural ou customizavel para dar uma liberdade real ao jogador e render muitas muitas horas de gameplay não lachante e não coreografada, trabalho nisso quando dá então vai ser demorado de fazer tudo ficar pronto, mas um dia foca bom."
run/main_scene="uid://xd0gh2k0h52c"
config/features=PackedStringArray("4.5", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://b8vcf8hijtbds"

[autoload]

DataManagement="*res://autoload/data_management.gd"
Globals="*res://autoload/globals.gd"

[display]

window/vsync/vsync_mode=0

[global_group]

stats_container=""
players_stats=""

